# Database
DATABASE_URL=postgresql://questara:change-me@db:5432/questara?sslmode=disable
POSTGRES_USER=questara
POSTGRES_PASSWORD=change-me
POSTGRES_DB=questara

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API
AI_PROVIDER=mock
CHECK_IN_RADIUS_METERS=200
PORT=3001
NODE_ENV=production

# Admin
NEXT_PUBLIC_API_URL=https://api.questara.example
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mobile
EXPO_PUBLIC_API_URL=https://api.questara.example
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
